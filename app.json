{
  "expo": {
    "name": "xBP",
    "slug": "xBP",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/res/mipmap-xhdpi/ic_launcher.png",
    "scheme": "xbp",
    "userInterfaceStyle": "automatic",
    "ios": {
      "icon": "./assets/expo.icon"
    },
    "android": {
      "permissions": [
        "READ_MEDIA_IMAGES",
        "WRITE_EXTERNAL_STORAGE",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.WRITE_EXTERNAL_STORAGE",
        "android.permission.READ_MEDIA_VISUAL_USER_SELECTED",
        "android.permission.READ_MEDIA_IMAGES",
        "android.permission.READ_MEDIA_VIDEO",
        "android.permission.READ_MEDIA_AUDIO"
      ],
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/images/res/mipmap-xhdpi/ic_launcher_foreground.png",
        "backgroundImage": "./assets/images/res/mipmap-xhdpi/ic_launcher_background.png",
        "monochromeImage": "./assets/images/res/mipmap-xhdpi/ic_launcher_monochrome.png"
      },
      "predictiveBackGestureEnabled": false,
      "package": "com.amourhamisiomar.xBP"
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/res/mipmap-xhdpi/ic_launcher_monochrome.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#208AEF",
          "android": {
            "image": "./assets/images/res/mipmap-xhdpi/ic_launcher_monochrome.png",
            "imageWidth": 76
          }
        }
      ],
      [
        "expo-media-library",
        {
          "photosPermission": "Allow access to save blood pressure cards.",
          "savePhotosPermission": "Allow saving images to your gallery."
        }
      ],
      "expo-sqlite",
      "expo-secure-store",
      "expo-asset"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "659d9ce9-7d46-4fff-a138-9981d92b6812"
      }
    },
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/659d9ce9-7d46-4fff-a138-9981d92b6812"
    }
  }
}
